    "requirements": [
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_memory.package.auto_capture",
        "priority": "must",
        "stability": "stable",
        "statement": "The plugin shall support auto-capture of configured signal patterns into structured memory records.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_memory.package.default_ets_path",
        "priority": "must",
        "stability": "stable",
        "statement": "The default shipped memory path shall be ETS-backed and use ETS as the authoritative store unless the caller supplies another store implementation.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_memory.package.plugin_and_actions",
        "priority": "must",
        "stability": "stable",
        "statement": "The package shall provide a Jido plugin and explicit actions for remember, recall, and forget flows.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_memory.package.structured_memory_contract",
        "priority": "must",
        "stability": "stable",
        "statement": "The package shall provide structured record and query contracts plus a runtime facade and store behavior for writing, retrieving, and deleting memory records.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/provider_architecture.spec.md",
        "id": "jido_memory.provider_architecture.contract_owner",
        "priority": "must",
        "stability": "evolving",
        "statement": "The canonical provider architecture proposal shall place the shared provider contract in jido_memory rather than in an implementation-specific advanced provider.",
        "subject_id": "jido_memory.provider_architecture"
      },
      {
        "file": ".spec/specs/provider_architecture.spec.md",
        "id": "jido_memory.provider_architecture.core_plus_capabilities",
        "priority": "must",
        "stability": "evolving",
        "statement": "The proposal shall separate required core provider operations from optional capability behaviors so minimal and advanced providers can coexist without a single oversized interface.",
        "subject_id": "jido_memory.provider_architecture"
      },
      {
        "file": ".spec/specs/provider_architecture.spec.md",
        "id": "jido_memory.provider_architecture.provider_roles",
        "priority": "must",
        "stability": "evolving",
        "statement": "The proposal shall treat the current runtime and store stack as the basic provider path and position jido_memory_os as an advanced provider implementation of the shared contract.",
        "subject_id": "jido_memory.provider_architecture"
      },
      {
        "file": ".spec/specs/provider_capabilities.spec.md",
        "id": "jido_memory.provider_capabilities.optional_behaviours",
        "priority": "must",
        "stability": "evolving",
        "statement": "Advanced memory features shall be expressed as optional capability behaviours separate from the required provider core contract.",
        "subject_id": "jido_memory.provider_capabilities"
      },
      {
        "file": ".spec/specs/provider_capabilities.spec.md",
        "id": "jido_memory.provider_capabilities.structured_discovery",
        "priority": "must",
        "stability": "evolving",
        "statement": "Providers shall expose capabilities as structured metadata rather than an untyped flat list so tooling and facades can reason about supported features.",
        "subject_id": "jido_memory.provider_capabilities"
      },
      {
        "file": ".spec/specs/provider_capabilities.spec.md",
        "id": "jido_memory.provider_capabilities.typed_unsupported_error",
        "priority": "must",
        "stability": "evolving",
        "statement": "The canonical layer shall return a typed unsupported-capability error when a caller requests a capability the configured provider does not implement.",
        "subject_id": "jido_memory.provider_capabilities"
      },
      {
        "file": ".spec/specs/provider_core.spec.md",
        "id": "jido_memory.provider_core.bootstrap_boundary",
        "priority": "must",
        "stability": "evolving",
        "statement": "Providers shall own their own bootstrap boundary through core callbacks so advanced implementations can attach supervision and provider metadata without leaking implementation-specific startup details into the facade.",
        "subject_id": "jido_memory.provider_core"
      },
      {
        "file": ".spec/specs/provider_core.spec.md",
        "id": "jido_memory.provider_core.provider_bundle_selection",
        "priority": "must",
        "stability": "evolving",
        "statement": "Applications shall select memory implementations as provider bundles identified by module plus opts rather than by wiring low-level implementation details directly into agent code.",
        "subject_id": "jido_memory.provider_core"
      },
      {
        "file": ".spec/specs/provider_core.spec.md",
        "id": "jido_memory.provider_core.required_behaviour",
        "priority": "must",
        "stability": "evolving",
        "statement": "The canonical provider layer shall define a required core behaviour that covers configuration validation, child spec declaration, initialization, capability reporting, and the base remember, get, retrieve, forget, prune, and info operations.",
        "subject_id": "jido_memory.provider_core"
      },
      {
        "file": ".spec/specs/provider_facade.spec.md",
        "id": "jido_memory.provider_facade.canonical_dispatch_boundary",
        "priority": "must",
        "stability": "evolving",
        "statement": "Actions and runtime-facing helpers shall dispatch through a canonical memory facade rather than calling provider-specific modules directly.",
        "subject_id": "jido_memory.provider_facade"
      },
      {
        "file": ".spec/specs/provider_facade.spec.md",
        "id": "jido_memory.provider_facade.provider_configurable_plugin",
        "priority": "must",
        "stability": "evolving",
        "statement": "Jido.Memory.Plugin shall be provider-configurable so the same agent-facing plugin and action API can target different memory implementations.",
        "subject_id": "jido_memory.provider_facade"
      },
      {
        "file": ".spec/specs/provider_facade.spec.md",
        "id": "jido_memory.provider_facade.shared_record_query_contract",
        "priority": "must",
        "stability": "evolving",
        "statement": "Jido.Memory.Record and the base Jido.Memory.Query contract shall remain canonical, while provider-specific retrieval features stay in backward-compatible options or hints rather than mandatory core fields.",
        "subject_id": "jido_memory.provider_facade"
      },
      {
        "file": ".spec/specs/provider_migration.spec.md",
        "id": "jido_memory.provider_migration.basic_provider_default",
        "priority": "must",
        "stability": "evolving",
        "statement": "The first provider implementation shall wrap the existing Jido.Memory.Runtime and Jido.Memory.Store path so current ETS-backed behavior remains the default.",
        "subject_id": "jido_memory.provider_migration"
      },
      {
        "file": ".spec/specs/provider_migration.spec.md",
        "id": "jido_memory.provider_migration.incremental_compatibility",
        "priority": "must",
        "stability": "evolving",
        "statement": "The provider architecture shall be introduced additively so existing runtime flows, record and store contracts, and default plugin usage continue to work while applications migrate incrementally.",
        "subject_id": "jido_memory.provider_migration"
      },
      {
        "file": ".spec/specs/provider_migration.spec.md",
        "id": "jido_memory.provider_migration.memory_os_integration",
        "priority": "must",
        "stability": "evolving",
        "statement": "jido_memory_os shall be integrated as an advanced provider implementation that satisfies the canonical provider contract plus the applicable optional capabilities.",
        "subject_id": "jido_memory.provider_migration"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.agents_present",
        "priority": "must",
        "stability": "stable",
        "statement": "The repository shall include a .spec/AGENTS.md that gives local operating guidance for agents editing current-truth subjects.",
        "subject_id": "spec.system"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.current_truth_boundary",
        "priority": "must",
        "stability": "stable",
        "statement": "Current-truth subject specs shall live in .spec/specs/, while supporting RFCs and design notes shall stay outside that directory.",
        "subject_id": "spec.system"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.decisions_readme_present",
        "priority": "must",
        "stability": "stable",
        "statement": "The repository shall include a .spec/decisions/README.md that explains when durable ADRs belong in the workspace.",
        "subject_id": "spec.system"
      },
      {
        "file": ".spec/specs/spec_system.spec.md",
        "id": "spec.workspace.readme_present",
        "priority": "must",
        "stability": "stable",
        "statement": "The repository shall include a .spec/README.md that explains the purpose, layout, and workflow for the local Spec Led workspace.",
        "subject_id": "spec.system"
      }
    ],
