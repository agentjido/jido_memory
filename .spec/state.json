        "id": "jido_memory.package.auto_capture",
        "priority": "must",
        "stability": "stable",
        "statement": "The plugin shall support auto-capture of configured signal patterns into structured memory records.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_memory.package.default_ets_path",
        "priority": "must",
        "stability": "stable",
        "statement": "The default shipped memory path shall be ETS-backed and use ETS as the authoritative store unless the caller supplies another store implementation.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_memory.package.plugin_and_actions",
        "priority": "must",
        "stability": "stable",
        "statement": "The package shall provide a Jido plugin and explicit actions for remember, recall, and forget flows.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/package.spec.md",
        "id": "jido_memory.package.structured_memory_contract",
        "priority": "must",
        "stability": "stable",
        "statement": "The package shall provide structured record and query contracts plus a runtime facade and store behavior for writing, retrieving, and deleting memory records.",
        "subject_id": "jido_memory.package"
      },
      {
        "file": ".spec/specs/provider_architecture.spec.md",
        "id": "jido_memory.provider_architecture.contract_owner",
        "priority": "must",
        "stability": "evolving",
        "statement": "The canonical provider architecture proposal shall place the shared provider contract in jido_memory rather than in an implementation-specific advanced provider.",
        "subject_id": "jido_memory.provider_architecture"
      },
      {
        "file": ".spec/specs/provider_architecture.spec.md",
        "id": "jido_memory.provider_architecture.core_plus_capabilities",
        "priority": "must",
        "stability": "evolving",
        "statement": "The proposal shall separate required core provider operations from optional capability behaviors so minimal and advanced providers can coexist without a single oversized interface.",
        "subject_id": "jido_memory.provider_architecture"
      },
      {
        "file": ".spec/specs/provider_architecture.spec.md",
        "id": "jido_memory.provider_architecture.provider_roles",
        "priority": "must",
        "stability": "evolving",
        "statement": "The proposal shall treat the current runtime and store stack as the basic provider path and position jido_memory_os as an advanced provider implementation of the shared contract.",
        "subject_id": "jido_memory.provider_architecture"
      },
      {
